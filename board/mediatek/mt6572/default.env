stdin=serial,button-kbd,mtk-keypad
stdout=serial,vidconsole
stderr=serial,vidconsole

kernel_addr_r=0x80008000
ramdisk_addr_r=0x84000000
fdt_addr_r=0x80000000

do_fastboot=echo "SLOWBOOT MODE =>"; \
	fastboot usb 0

do_usbacm=setenv stdin serial,button-kbd,mtk-keypad,usbacm; \
	setenv stdout serial,vidconsole,usbacm; \
	setenv stderr serial,vidconsole,usbacm;

bootmenu_0=Enable fastboot mode=run do_fastboot
bootmenu_1=Enable USB serial=run do_usbacm

bootcmd=bootmenu
bootmenu_delay=3
